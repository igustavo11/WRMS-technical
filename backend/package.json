{
	"name": "backend",
	"module": "server.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/server.ts",
		"start": "bun src/server.ts",
		"db:generate": "bunx prisma generate",
		"db:migrate": "bunx prisma migrate dev",
		"db:seed": "bunx prisma db seed",
		"db:push:test": "set -a && . ./.env.test && set +a && bunx prisma db push",
		"lint": "biome check --write src/",
		"format": "biome format --write src/",
		"check": "biome check --write src/",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "latest",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.9.3",
		"@types/supertest": "^7.2.0",
		"prisma": "^7.8.0",
		"supertest": "^7.2.2",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^6.0.0",
		"@fastify/type-provider-zod": "^1.0.0",
		"@prisma/adapter-mssql": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"jsonwebtoken": "^9.0.3",
		"mssql": "^12.5.5",
		"zod": "^4.4.3"
	}
}
